// Données du contrat signé, stockées pour la génération PDF
let SIGNED_LD = null;

function doSign(){
  if(!document.getElementById('btn-sign').classList.contains('ok')) return;
  SIGNED_LD = {nom:gv('l_n'), adr:gv('l_a'), tel:gv('l_t'), pid:gv('l_p')};

  // Aperçu dans l'écran "done"
  const html = buildCT(SIGNED_LD);
