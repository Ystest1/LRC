let idPhoto1=null, idPhoto2=null; // Fichiers pièce d'identité {data, type, name, isImage}

function loadIDPhoto(input, photoId, btnId, prevId, lblId){
  var file = input.files[0];
  if(!file) return;
  var reader = new FileReader();
  reader.onload = function(e){
    var dataUrl = e.target.result;
    var isImage = file.type.startsWith('image/');
    // Stocker : { data, type, name, isImage }
    var obj = { data: dataUrl, type: file.type, name: file.name, isImage: isImage };
    if(photoId === 'id1') idPhoto1 = obj;
    else idPhoto2 = obj;
    // Aperçu : image si possible, sinon icône fichier
    var prev = document.getElementById(prevId);
    if(isImage){
      prev.src = dataUrl;
      prev.style.display = 'block';
    } else {
      prev.style.display = 'none';
    }
    // Style bouton + label
    document.getElementById(btnId).classList.add('loaded');
    var shortName = file.name.length > 18 ? file.name.substring(0,16)+'…' : file.name;
    document.getElementById(lblId).textContent = shortName;
  };
  reader.readAsDataURL(file);
}

/* ── SCREENS ── */
function show(id){
  document.querySelectorAll('.scr').forEach(e=>e.classList.remove('on'));
  if(id) document.getElementById(id).classList.add('on');
}

/* ── BOOT ── */
window.addEventListener('load',()=>{
  const h=window.location.hash;
  if(h && h.startsWith('#d=')){
    document.getElementById('login-bg').classList.remove('on');
    loadClient(h.slice(3));
  } else {
    setTimeout(()=>document.getElementById('pwd').focus(),100);
  }
});
window.addEventListener('hashchange',()=>{
  const h=window.location.hash;
  if(h && h.startsWith('#d=')){ document.getElementById('login-bg').classList.remove('on'); loadClient(h.slice(3)); }
});

/* ── LOGIN ── */
function doLogin(){
  if(document.getElementById('pwd').value===PWD){
    document.getElementById('login-bg').classList.remove('on');
    show('s-form'); initSig('b');
  } else {
    const e=document.getElementById('perr');
    e.style.display='block'; setTimeout(()=>e.style.display='none',1500);
