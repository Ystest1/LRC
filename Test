function generatePDF(){
  if(!SIGNED_LD){ alert('Aucun contrat à télécharger.'); return; }
  const ld = SIGNED_LD;

  const btn = document.querySelector('#s-done button[onclick="generatePDF()"]');
  if(btn){ btn.textContent = '⏳ Génération…'; btn.disabled = true; }

  try {
    const { jsPDF } = window.jspdf;
    if(!jsPDF){ throw new Error('jsPDF non chargé'); }
    const doc = new jsPDF({ orientation:'portrait', unit:'mm', format:'a4' });

    const PW=210, ML=14, MR=14, MT=14, MB=280;
    const CW=PW-ML-MR;
    let y=MT;

    // Valeurs sûres (jamais undefined)
    const bn  = String(BD.n  || '');
    const ba  = String(BD.a  || '');
    const bs  = String(BD.s  || '');
    const bdd = String(BD.dd || '');
    const bdf = String(BD.df || '');
    const bha = String(BD.ha || '');
    const bhd = String(BD.hd || '');
    const bmt = String(BD.mt || '');
    const bdg = String(BD.dg || '');
    const bls = String(BD.ls || '');
    const bds = String(BD.ds || '');
    const arr = bdd + (bha ? ' à ' + bha : '');
    const dep = bdf + (bhd ? ' à ' + bhd : '');

    // ── Helpers ──
    const DARK  = [26,18,8];
    const GOLD  = [201,165,90];
    const BROWN = [139,94,26];
    const GRAY  = [100,90,80];

    function newPage(){ doc.addPage(); y = MT; }
    function chk(h){ if(y+h > MB) newPage(); }

    function setFont(style, size, color){
      doc.setFont('helvetica', style);
      doc.setFontSize(size);
      doc.setTextColor(color[0], color[1], color[2]);
    }

    // Écrire du texte avec wrap automatique, retourne la hauteur occupée
    function writeText(text, x, maxW, lineH){
      const lines = doc.splitTextToSize(text, maxW);
      lines.forEach(function(line){
        chk(lineH);
        doc.text(line, x, y);
        y += lineH;
      });
    }

    // Bloc encadré (bailleur / locataire)
    function drawBloc(rows){
      var lineH = 4.5;
      var padding = 3;
      // Calculer hauteur totale du bloc
      var totalH = padding;
      rows.forEach(function(r){
        var lines = doc.splitTextToSize(r.t, CW - 8);
        totalH += lines.length * lineH;
      });
      totalH += padding;
      chk(totalH + 4);
      doc.setFillColor(253,248,234);
      doc.setDrawColor(220,200,160);
      doc.setLineWidth(0.3);
      doc.roundedRect(ML, y, CW, totalH, 2, 2, 'FD');
      y += padding;
      rows.forEach(function(r){
        var lines = doc.splitTextToSize(r.t, CW - 8);
        if(r.bold){       setFont('bold',   9, DARK);  }
        else if(r.brown){ setFont('bold',   9, BROWN); }
        else if(r.italic){setFont('italic', 9, GRAY);  }
        else{             setFont('normal', 9, DARK);  }
        lines.forEach(function(line){
          chk(lineH);
          doc.text(line, ML+4, y);
          y += lineH;
        });
      });
      y += padding + 2;
    }

    // Article avec titre gras + corps normal
    function drawArt(title, body){
      var lineH = 4.3;
      var titleH = 5;
      chk(titleH + lineH + 2);
      setFont('bold', 9, DARK);
      doc.text(title, ML, y);
      y += titleH;
      setFont('normal', 9, [40,30,20]);
      writeText(body, ML, CW, lineH);
      y += 2;
    }

    // ══════════════════════════════════════
    // TITRE
    // ══════════════════════════════════════
    setFont('bold', 15, DARK);
    doc.text('Contrat de Location Saisonnière Meublée', PW/2, y, {align:'center'});
    y += 5;
    doc.setDrawColor(GOLD[0],GOLD[1],GOLD[2]);
    doc.setLineWidth(0.6);
    doc.line(ML, y, ML+CW, y);
    y += 6;

    setFont('bold', 10, DARK);
    doc.text('Entre les soussignés :', ML, y);
    y += 6;

    // ══════════════════════════════════════
    // BLOCS PARTIES
    // ══════════════════════════════════════
    drawBloc([
      {t:'Le Bailleur', bold:true},
      {t:'Nom / Dénomination : ' + bn, brown:true},
      {t:'Adresse : ' + ba, brown:true},
      {t:'SIRET : ' + bs, brown:true},
      {t:'Ci-après désigné « le Bailleur »', italic:true}
    ]);

    drawBloc([
      {t:'Et le(s) Locataire(s)', bold:true},
      {t:'Nom : ' + ld.nom, brown:true},
      {t:'Adresse : ' + ld.adr, brown:true},
      {t:'Téléphone : ' + ld.tel, brown:true},
      {t:"Pièce d'identité n° : " + ld.pid, brown:true},
      {t:"Ci-après désigné « le Locataire »", italic:true}
    ]);

    y += 2;

    // ══════════════════════════════════════
    // ARTICLES
    // ══════════════════════════════════════
    drawArt('Article 1 – Objet du contrat',
      "Le présent contrat a pour objet la location saisonnière, à titre de résidence provisoire et de loisir, d'un logement meublé et équipé, à usage exclusif d'habitation. Le logement ne doit en aucun cas être utilisé comme résidence principale ni pour l'organisation de fêtes.");

    drawArt('Article 2 – Désignation du logement',
      "Adresse : 37 rue de l'église, 93420 Villepinte, bâtiment C porte 201\nType : Appartement meublé de standing\nÉquipements : lit double, jacuzzi privatif, télévision, linge de maison fourni, kitchenette équipée, salle de bain avec douche, etc.\nCapacité maximale : 2 personnes — Non-fumeur – Animaux non autorisés");

    drawArt('Article 3 – Durée de la location',
      "La location est conclue du : " + bdd + " au " + bdf + "\nArrivée : " + arr + " — Départ : " + dep + "\nLa location ne pourra être prolongée sans l'accord préalable du Bailleur.");

    drawArt('Article 4 – Prix et modalités de paiement',
      "Montant total de la location : " + bmt + "\nDépôt de garantie : " + bdg + " — restitué sous 24h après le départ, sauf retenue justifiée.");

    drawArt('Article 5 – État des lieux',
      "Un état des lieux et un inventaire sommaire sont réalisés à l'arrivée et au départ. Toute anomalie doit être signalée dans l'heure suivant l'entrée dans les lieux.");

    drawArt('Article 6 – Obligations du locataire',
      "Le locataire s'engage à lire et respecter le règlement intérieur, respecter la capacité maximale, ne pas organiser de fête sans autorisation, ne pas fumer, utiliser le jacuzzi conformément aux règles, et restituer le logement propre. Le non-respect peut entraîner l'expulsion immédiate sans remboursement ainsi que le retrait du dépôt de garantie.");

    drawArt('Article 6 bis – Utilisation des équipements – responsabilité',
      "Le locataire reconnaît utiliser les équipements (jacuzzi, éclairages, enceinte Bluetooth, etc.) sous sa seule responsabilité et s'engage à les utiliser de façon conforme. Le bailleur ne pourra être tenu responsable des blessures, incidents ou pannes liées à un mauvais usage.");

    drawArt('Article 7 – Assurance et responsabilité',
      "Le locataire est seul responsable pendant son séjour et doit être couvert par une assurance responsabilité civile. Le bailleur décline toute responsabilité pour les dommages ou pertes subis par le locataire ou ses invités.");

    drawArt('Article 8 – Annulation / Interruption de séjour',
      'Toute annulation doit être notifiée par écrit.');

    drawArt('Article 9 – Litiges',
      'Tout litige relèvera du tribunal du ressort du logement loué.');

    drawArt('Article 10 – Acceptation des risques',
      "Le locataire accepte les risques liés à l'usage du logement et de ses équipements et déclare les utiliser de façon responsable. Le bailleur ne pourra être tenu responsable en cas d'utilisation inadaptée ou imprudente.");

    // ══════════════════════════════════════
    // LIEU ET DATE
    // ══════════════════════════════════════
    y += 2;
    chk(8);
    setFont('normal', 9.5, DARK);
    doc.text('Fait à ' + bls + ', le ' + bds, ML, y);
    y += 10;

    // ══════════════════════════════════════
    // SIGNATURES
    // ══════════════════════════════════════
    chk(50);
    doc.setDrawColor(200,185,160);
    doc.setLineWidth(0.4);
    doc.line(ML, y, ML+CW, y);
    y += 6;

    var sigY = y;
    var col2 = ML + CW/2 + 5;
    var colW = CW/2 - 5;

    // -- Bailleur (gauche) --
    setFont('bold', 9, DARK);
    doc.text('Signature du Bailleur :', ML, sigY);
    setFont('bold', 9, BROWN);
    doc.text(bn, ML, sigY + 5);

    if(BD.sb && BD.sb.length > 100){
      try{
        // Détecter le type (jpeg ou png)
        var imgType = BD.sb.indexOf('image/jpeg') > -1 ? 'JPEG' : 'PNG';
        doc.addImage(BD.sb, imgType, ML, sigY + 8, 55, 22);
      } catch(e){
        doc.setDrawColor(180,160,130); doc.setLineWidth(0.3);
        doc.rect(ML, sigY+8, 55, 22);
      }
    } else {
      doc.setDrawColor(180,160,130); doc.setLineWidth(0.3);
      doc.rect(ML, sigY+8, 55, 22);
    }

    // -- Locataire (droite) --
    setFont('bold', 9, DARK);
    doc.text('Signature du Locataire :', col2, sigY);
    setFont('italic', 8.5, GRAY);
    doc.text("« lu et approuvé » — " + ld.nom, col2, sigY + 5);

    if(sigL && sigL.length > 100){
      try{
        doc.addImage(sigL, 'PNG', col2, sigY + 8, 55, 22);
      } catch(e){
        doc.setDrawColor(180,160,130); doc.setLineWidth(0.3);
        doc.rect(col2, sigY+8, 55, 22);
      }
    } else {
      doc.setDrawColor(180,160,130); doc.setLineWidth(0.3);
      doc.rect(col2, sigY+8, 55, 22);
    }

    // ══════════════════════════════════════
    // PHOTOS PIÈCE D'IDENTITÉ (si fournies)
    // ══════════════════════════════════════
    if(idPhoto1 || idPhoto2){
      doc.addPage();
      y = MT;
      setFont('bold', 12, DARK);
      doc.text("Pièce d'identité du Locataire", ML, y);
      y += 4;
      doc.setDrawColor(GOLD[0],GOLD[1],GOLD[2]);
      doc.setLineWidth(0.5);
      doc.line(ML, y, ML+CW, y);
      y += 8;
      setFont('normal', 9, GRAY);
      doc.text('Locataire : ' + ld.nom + '  —  N° : ' + ld.pid, ML, y);
      y += 10;

      // Afficher chaque photo en pleine largeur (ratio conservé)
      var photos = [];
      // idPhoto1/2 sont des objets {data, type, name, isImage}
      if(idPhoto1) photos.push({data: idPhoto1.data, type: idPhoto1.type, name: idPhoto1.name, isImage: idPhoto1.isImage, label: 'Recto'});
      if(idPhoto2) photos.push({data: idPhoto2.data, type: idPhoto2.type, name: idPhoto2.name, isImage: idPhoto2.isImage, label: 'Verso'});

      photos.forEach(function(photo){
        try {
          chk(20);
          setFont('bold', 8, BROWN);
          doc.text(photo.label, ML, y);
          y += 5;

          if(photo.isImage){
            // Fichier image : afficher dans le PDF
            var imgType = photo.data.indexOf('image/png') > -1 ? 'PNG' :
                          photo.data.indexOf('image/webp') > -1 ? 'WEBP' : 'JPEG';
            var imgEl = new Image();
            imgEl.src = photo.data;
            var iw = imgEl.naturalWidth || 800;
            var ih = imgEl.naturalHeight || 500;
            var ratio = ih / iw;
            var dispW = CW;
            var dispH = Math.min(dispW * ratio, 110);
            dispW = dispH / ratio;
            chk(dispH + 6);
            doc.addImage(photo.data, imgType, ML, y, dispW, dispH);
            y += dispH + 10;
          } else {
            // Fichier non-image (PDF, scan) : indiquer le nom du fichier
            doc.setFillColor(248,245,238);
            doc.setDrawColor(200,180,140);
            doc.setLineWidth(0.4);
            doc.roundedRect(ML, y, CW, 14, 2, 2, 'FD');
            setFont('normal', 9, DARK);
            doc.text('Fichier joint : ' + (photo.name || 'inconnu'), ML + 4, y + 9);
            y += 20;
            setFont('normal', 8, GRAY);
            doc.text('(Le fichier a été transmis séparément via le système de notification)', ML, y);
            y += 10;
          }
        } catch(imgErr){
          setFont('normal', 9, GRAY);
          doc.text('[Fichier non lisible : ' + (photo.name||'?') + ']', ML, y);
          y += 8;
        }
      });
    }

    // ══════════════════════════════════════
    // GÉNÉRATION BLOB PDF
    // ══════════════════════════════════════
    var filename = 'contrat_luxury_room_' + ld.nom.replace(/[^a-zA-Z0-9]/g,'_') + '.pdf';
    var pdfBytes = doc.output('arraybuffer');
    var pdfBlob = new Blob([pdfBytes], {type:'application/pdf'});

    // ══════════════════════════════════════
    // ENVOI PDF SUR TELEGRAM
    // ══════════════════════════════════════
    var BOT_TOKEN = '8367114879:AAHBwEpl7ADsUbLSA8YUOQaJGT-XXPVwgSw';
    var CHAT_ID   = '7743785635';

    var bn2  = String(BD.n  || 'Bailleur');
    var bdd2 = String(BD.dd || '');
    var bdf2 = String(BD.df || '');
    var bha2 = String(BD.ha || '');
    var bhd2 = String(BD.hd || '');
    var bmt2 = String(BD.mt || '');
    var bdg2 = String(BD.dg || '');
    var bls2 = String(BD.ls || '');
    var bds2 = String(BD.ds || '');
    var arr2 = bdd2 + (bha2 ? ' a ' + bha2 : '');
    var dep2 = bdf2 + (bhd2 ? ' a ' + bhd2 : '');
    var NL2  = String.fromCharCode(10);
    var caption = [
      'Nouveau contrat signe !',
      '',
      'Locataire : ' + ld.nom,
      'Tel : ' + ld.tel,
      'Piece identite : ' + ld.pid,
      '',
      'Sejour : ' + arr2 + ' -> ' + dep2,
      'Montant : ' + bmt2,
      'Depot : ' + bdg2,
      '',
      'Signe a ' + bls2 + ' le ' + bds2
    ].join(NL2);

    try {
      var formData = new FormData();
      formData.append('chat_id', CHAT_ID);
      formData.append('document', pdfBlob, filename);
      formData.append('caption', caption);

      fetch('https://api.telegram.org/bot' + BOT_TOKEN + '/sendDocument', {
        method: 'POST',
        body: formData
      })
      .then(function(r){ return r.json(); })
      .then(function(data){
        if(data.ok){ console.log('Telegram: PDF envoyé'); }
        else{ console.warn('Telegram sendDocument erreur:', data.description); }
      })
      .catch(function(e){ console.warn('Telegram PDF error:', e); });

      // Envoyer les fichiers pièce d'identité non-image séparément sur Telegram
      [idPhoto1, idPhoto2].forEach(function(idFile, idx){
        if(!idFile || idFile.isImage) return; // les images sont déjà dans le PDF
        try {
          var byteStr = atob(idFile.data.split(',')[1]);
          var ab = new ArrayBuffer(byteStr.length);
          var ia = new Uint8Array(ab);
          for(var i=0;i<byteStr.length;i++) ia[i]=byteStr.charCodeAt(i);
          var fileBlob = new Blob([ab], {type: idFile.type || 'application/octet-stream'});
          var fd2 = new FormData();
          fd2.append('chat_id', CHAT_ID);
          fd2.append('document', fileBlob, idFile.name);
          fd2.append('caption', 'Piece identite ' + (idx===0?'recto':'verso') + ' - ' + ld.nom);
          fetch('https://api.telegram.org/bot' + BOT_TOKEN + '/sendDocument', {
            method:'POST', body:fd2
          }).then(function(r){ return r.json(); })
            .then(function(d){ console.log('Telegram: pièce identité envoyée', d.ok); })
            .catch(function(e){ console.warn('Telegram ID error:', e); });
        } catch(e){ console.warn('Envoi pièce identité:', e); }
      });

    } catch(te){
      console.warn('Telegram envoi impossible:', te);
    }

    // ══════════════════════════════════════
    // TÉLÉCHARGEMENT CLIENT
    // ══════════════════════════════════════
    var url = URL.createObjectURL(pdfBlob);
    var isIOS = /iPad|iPhone|iPod/.test(navigator.userAgent) && !window.MSStream;
    if(isIOS){
      window.open(url, '_blank');
    } else {
      var a = document.createElement('a');
      a.href = url; a.download = filename;
      document.body.appendChild(a); a.click(); document.body.removeChild(a);
    }
    setTimeout(function(){ URL.revokeObjectURL(url); }, 15000);

  } catch(err){
    console.error('PDF error:', err);
    alert('Erreur PDF : ' + err.message + '. Réessayez ou contactez le support.');
  } finally {
    if(btn){ btn.textContent = '⬇ Télécharger le PDF'; btn.disabled = false; }
  }
}

/* ── CONSTRUCTION DU HTML CONTRAT ── */
function esc(s){return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');}
function xv(v){ return v&&String(v).trim()?`<span class="vl">${esc(v)}</span>`:`<span style="color:#c0a060;font-style:italic;font-size:11px;">—</span>`; }

function buildCT(ld){
  // Signature bailleur : encodée dans le lien
  const sB = BD.sb
    ? `<img class="sig-img" src="${BD.sb}" alt="Signature bailleur" style="display:block;width:160px;height:55px;object-fit:contain;border:1px solid #e0d0b0;border-radius:4px;background:#fff;">`
    : `<div style="width:160px;height:55px;border:1px dashed #ccc;border-radius:4px;background:#fafaf8;"></div>`;

  // Signature locataire : disponible seulement après signature
  const sL = (ld && sigL)
    ? `<img class="sig-img" src="${sigL}" alt="Signature locataire" style="display:block;width:160px;height:55px;object-fit:contain;border:1px solid #e0d0b0;border-radius:4px;background:#fff;">`
    : `<div style="width:160px;height:55px;border:1px dashed #ccc;border-radius:4px;background:#fafaf8;display:flex;align-items:center;justify-content:center;"><span style="font-family:'Cormorant Garamond',serif;font-size:11px;color:#bbb;font-style:italic;">à signer</span></div>`;

  const nom  = ld ? `<span class="vl">${esc(ld.nom)}</span>` : `<span style="color:#c0a060;font-style:italic;font-size:11px;">à compléter</span>`;
  const adr  = ld ? `<span class="vl">${esc(ld.adr)}</span>` : `<span style="color:#c0a060;font-style:italic;font-size:11px;">à compléter</span>`;
  const tel  = ld ? `<span class="vl">${esc(ld.tel)}</span>` : `<span style="color:#c0a060;font-style:italic;font-size:11px;">à compléter</span>`;
  const pid  = ld ? `<span class="vl">${esc(ld.pid)}</span>` : `<span style="color:#c0a060;font-style:italic;font-size:11px;">à compléter</span>`;

  return `<div class="ct">
<h2>Contrat de Location Saisonnière Meublée</h2>
<p style="margin-bottom:10px;font-weight:600;">Entre les soussignés :</p>

<div class="bl">
  <p><strong>Le Bailleur</strong></p>
  <p>Nom / Dénomination : ${xv(BD.n)}</p>
  <p>Adresse : ${xv(BD.a)}</p>
  <p>SIRET : ${xv(BD.s)}</p>
  <p style="font-style:italic;margin-top:4px;">Ci-après désigné « le Bailleur »</p>
</div>

<div class="bl">
  <p><strong>Et le(s) Locataire(s)</strong></p>
  <p>Nom : ${nom}</p>
  <p>Adresse : ${adr}</p>
  <p>Téléphone : ${tel}</p>
  <p>Pièce d'identité n° : ${pid}</p>
  <p style="font-style:italic;margin-top:4px;">Ci-après désigné « le Locataire »</p>
</div>

<div class="ar">
  <p>Article 1 – Objet du contrat</p>
  <p>Le présent contrat a pour objet la location saisonnière, à titre de résidence provisoire et de loisir, d'un logement meublé et équipé, à usage exclusif d'habitation. Le logement ne doit en aucun cas être utilisé comme résidence principale ni pour l'organisation de fêtes.</p>
</div>
<div class="ar">
  <p>Article 2 – Désignation du logement</p>
  <p>Adresse : 37 rue de l'église, 93420 Villepinte, bâtiment C porte 201<br>Type : Appartement meublé de standing<br>Équipements principaux : lit double, jacuzzi privatif, télévision, linge de maison fourni, kitchenette équipée, salle de bain avec douche, etc.<br>Capacité maximale d'accueil : 2 personnes — Non-fumeur – Animaux non autorisés</p>
</div>
<div class="ar">
  <p>Article 3 – Durée de la location</p>
  <p>La location est conclue pour une durée déterminée, du : ${xv(BD.dd)} au ${xv(BD.df)}<br>Date et heure d'arrivée : <span class="vl">${esc((BD.dd||'')+(BD.ha?' à '+BD.ha:''))}</span><br>Date et heure de départ : <span class="vl">${esc((BD.df||'')+(BD.hd?' à '+BD.hd:''))}</span><br>La location ne pourra être prolongée sans l'accord préalable du Bailleur.</p>
</div>
<div class="ar">
  <p>Article 4 – Prix et modalités de paiement</p>
  <p>Montant total de la location : ${xv(BD.mt)}<br>Un dépôt de garantie de ${xv(BD.dg)} sera demandé à l'arrivée. Il sera restitué au maximum 24h après le départ, sauf retenue justifiée telle qu'une casse ou un manquement au contrat de la part du locataire.</p>
</div>
<div class="ar">
  <p>Article 5 – État des lieux</p>
  <p>Un état des lieux et un inventaire sommaire sont réalisés à l'arrivée et au départ. Toute anomalie doit être signalée dans l'heure suivant l'entrée dans les lieux.</p>
</div>
<div class="ar">
  <p>Article 6 – Obligations du locataire</p>
  <p>Le locataire s'engage à lire et respecter le règlement intérieur reçu et affiché, respecter la capacité maximale, ne pas organiser de fête sans autorisation, ne pas fumer, utiliser le jacuzzi conformément aux règles, et restituer le logement propre. Le non-respect peut entraîner l'expulsion immédiate sans remboursement ainsi que le retrait d'une partie ou de la totalité du dépôt de garantie.</p>
</div>
<div class="ar">
  <p>Article 6 bis – Utilisation des équipements – responsabilité</p>
  <p>Le locataire reconnaît utiliser les équipements (jacuzzi, éclairages, enceinte Bluetooth, etc.) sous sa seule responsabilité et s'engage à les utiliser de façon conforme. Le bailleur ne pourra être tenu responsable des blessures, incidents ou pannes liées à un mauvais usage.</p>
</div>
<div class="ar">
  <p>Article 7 – Assurance et responsabilité</p>
  <p>Le locataire est seul responsable pendant son séjour et doit être couvert par une assurance responsabilité civile. Le bailleur décline toute responsabilité pour les dommages ou pertes subis par le locataire ou ses invités.</p>
</div>
<div class="ar">
  <p>Article 8 – Annulation / Interruption de séjour</p>
  <p>Toute annulation doit être notifiée par écrit.</p>
</div>
<div class="ar">
  <p>Article 9 – Litiges</p>
  <p>Tout litige relèvera du tribunal du ressort du logement loué.</p>
</div>
<div class="ar">
  <p>Article 10 – Acceptation des risques</p>
  <p>Le locataire accepte les risques liés à l'usage du logement et de ses équipements et déclare les utiliser de façon responsable. Le bailleur ne pourra être tenu responsable en cas d'utilisation inadaptée ou imprudente.</p>
</div>

<p style="margin-top:14px;">Fait à ${xv(BD.ls)}, le ${xv(BD.ds)}</p>

<div class="sigs">
  <div class="sbox">
    <p class="stitle">Signature du Bailleur :</p>
    <p class="sname">${esc(BD.n||'')}</p>
    ${sB}
  </div>
  <div class="sbox">
    <p class="stitle">Signature du Locataire :</p>
    <p class="sname-gray">« lu et approuvé »${ld?' — '+esc(ld.nom):''}</p>
    ${sL}
  </div>
</div>
</div>`;
}

/* ── SIGNATURE PAD ── */
function initSig(id){
  const c=document.getElementById('cv-'+id), ctx=c.getContext('2d');
  c.width=c.offsetWidth||280;
  ctx.fillStyle='#fffef9'; ctx.fillRect(0,0,c.width,c.height);
  ctx.strokeStyle='#1d2322'; ctx.lineWidth=2.2; ctx.lineCap='round'; ctx.lineJoin='round';
  let drawing=false;
  function gp(e){
    const r=c.getBoundingClientRect(), sx=c.width/r.width, sy=c.height/r.height;
    const s=e.touches?e.touches[0]:e;
    return {x:(s.clientX-r.left)*sx, y:(s.clientY-r.top)*sy};
  }
  c.addEventListener('mousedown',e=>{e.preventDefault();drawing=true;const p=gp(e);ctx.beginPath();ctx.moveTo(p.x,p.y);});
  c.addEventListener('mousemove',e=>{if(!drawing)return;const p=gp(e);ctx.lineTo(p.x,p.y);ctx.stroke();onDraw(id,c);});
  c.addEventListener('mouseup',()=>drawing=false);
  c.addEventListener('mouseleave',()=>drawing=false);
  c.addEventListener('touchstart',e=>{e.preventDefault();drawing=true;const p=gp(e);ctx.beginPath();ctx.moveTo(p.x,p.y);},{passive:false});
  c.addEventListener('touchmove',e=>{e.preventDefault();if(!drawing)return;const p=gp(e);ctx.lineTo(p.x,p.y);ctx.stroke();onDraw(id,c);},{passive:false});
  c.addEventListener('touchend',()=>drawing=false);
}
function onDraw(id,c){
  document.getElementById('ph-'+id).style.display='none';
  document.getElementById('sc-'+id).style.display='inline';
  if(id==='b'){ sigB=c.toDataURL('image/jpeg',0.2); }
  else { sigL=c.toDataURL('image/png'); hasL=true; chkC(); }
}
function clr(id){
  const c=document.getElementById('cv-'+id), ctx=c.getContext('2d');
  ctx.fillStyle='#fffef9'; ctx.fillRect(0,0,c.width,c.height);
  document.getElementById('ph-'+id).style.display='flex';
  document.getElementById('sc-'+id).style.display='none';
  if(id==='b'){ sigB=null; }
  else { sigL=null; hasL=false; chkC(); }
}
</script>

