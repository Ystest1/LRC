<style>
*{box-sizing:border-box;margin:0;padding:0;}
body{background:#f8f6f2;font-family:'Lato',sans-serif;min-height:100vh;}
input{font-family:'Cormorant Garamond',serif!important;}
.hdr{background:#1d2322;padding:14px 28px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:10px;}
.hdr-brand{display:flex;align-items:center;gap:12px;}
.hdr h1{font-family:'Cormorant Garamond',serif;font-size:20px;color:#c9a55a;font-weight:600;}
.hdr p{font-size:9px;color:#6a7070;letter-spacing:2px;text-transform:uppercase;}
.hdr-btns{display:flex;gap:8px;flex-wrap:wrap;}
.btn{padding:9px 18px;border-radius:6px;cursor:pointer;font-family:'Lato',sans-serif;font-size:13px;font-weight:600;border:none;transition:all .18s;}
.btn:hover{filter:brightness(1.1);}
.btn-out{background:#f8f6f2;color:#7a6a30;border:1px solid #d4c090!important;}
.btn-red{background:#3a1010;color:#e88888;}
.btn-full{width:100%;padding:15px;font-family:'Cormorant Garamond',serif;font-size:19px;font-weight:700;border-radius:8px;border:none;transition:all .2s;cursor:not-allowed;background:#c5b89a;color:#9a8a6a;}
.btn-full.ok{background:#1d2322;color:#c9a55a;cursor:pointer;}
.wrap{max-width:700px;margin:0 auto;padding:32px 20px;}
.card{background:#fff;border:1px solid #e8dcc8;border-radius:10px;padding:22px 26px;margin-bottom:18px;box-shadow:0 1px 8px rgba(0,0,0,.04);}
.card h3{font-family:'Cormorant Garamond',serif;font-size:16px;color:#2c1f0e;margin-bottom:14px;padding-bottom:10px;border-bottom:1px solid #f0e8d4;}
.g2{display:grid;grid-template-columns:1fr 1fr;gap:0 20px;}
@media(max-width:520px){.g2{grid-template-columns:1fr;}}
.f{margin-bottom:16px;}
.f label{display:block;font-family:'Cormorant Garamond',serif;font-size:12px;color:#aaa;text-transform:uppercase;letter-spacing:1.2px;margin-bottom:5px;transition:color .2s;}
.f label.hi{color:#7a6a30;}
.f input{width:100%;padding:10px 13px;font-family:'Cormorant Garamond',serif;font-size:15px;border:1.5px solid #e0d5c5;border-radius:6px;background:#faf8f4;color:#2c2416;outline:none;transition:all .2s;}
.f input:focus{border-color:#c9a55a;background:#fffef5;}
.f input.hi{border-color:#c9a55a;background:#fffef5;}
.f input[readonly]{background:#f7f3ec;border-color:#e8dcc8;color:#5a4a30;cursor:default;}
.req{color:#c0392b;}

/* UPLOAD PIÈCE D’IDENTITÉ */
.upload-zone{
display:flex;gap:12px;flex-wrap:wrap;margin-top:8px;
}
.upload-btn{
flex:1;min-width:120px;
border:1.5px dashed #d4c5a9;border-radius:6px;
padding:16px 10px;text-align:center;
cursor:pointer;transition:all .2s;background:#faf8f4;
position:relative;overflow:hidden;
}
.upload-btn:hover{border-color:#c9a55a;background:#fffef5;}
.upload-btn.loaded{border-color:#c9a55a;border-style:solid;background:#fffef5;}
.upload-btn input[type=file]{
position:absolute;inset:0;opacity:0;cursor:pointer;width:100%;height:100%;
}
.upload-btn .upload-icon{font-size:22px;margin-bottom:6px;}
.upload-btn .upload-label{font-family:‘Lato’,sans-serif;font-size:11px;color:#a09080;letter-spacing:0.5px;}
.upload-btn.loaded .upload-label{color:#8b5e1a;font-weight:600;}
.upload-preview{
width:100%;max-height:80px;object-fit:cover;
border-radius:4px;margin-top:6px;display:none;
}
.upload-btn.loaded .upload-preview{display:block;}
.rgpd-note{
font-family:‘Lato’,sans-serif;font-size:11px;color:#a09080;
line-height:1.5;margin-top:10px;padding:10px 12px;
background:#fdf9f0;border-left:3px solid #e8c96a;border-radius:0 4px 4px 0;
}
.sh{display:flex;justify-content:space-between;align-items:center;margin-bottom:7px;}
.sl{font-family:‘Cormorant Garamond’,serif;font-size:13px;color:#7a7060;letter-spacing:1px;text-transform:uppercase;}
.scbtn{font-size:11px;color:#c0392b;background:none;border:1px solid #c0392b;border-radius:4px;padding:2px 9px;cursor:pointer;display:none;}
.sw{position:relative;border:1.5px solid #d4c5a9;border-radius:8px;overflow:hidden;background:#fffef9;max-width:280px;}
.sw canvas{width:100%;display:block;cursor:crosshair;touch-action:none;}
.sph{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;pointer-events:none;}
.sph span{font-family:‘Cormorant Garamond’,serif;font-size:13px;color:#c4b49a;font-style:italic;}
.ai{background:#fff8ee;border:1px solid #f0d9a0;border-radius:10px;padding:14px 18px;margin-bottom:22px;display:flex;gap:10px;}
.ai p{font-family:‘Lato’,sans-serif;font-size:13px;color:#7a5a10;line-height:1.6;}
.aok{background:#e8f5e9;border:1.5px solid #a5d6a7;border-radius:10px;padding:18px 22px;margin-bottom:22px;display:flex;align-items:center;gap:14px;flex-wrap:wrap;}
.aok p{font-family:‘Cormorant Garamond’,serif;font-size:18px;color:#1b5e20;font-weight:600;}
.aok small{font-family:‘Lato’,sans-serif;font-size:13px;color:#388e3c;margin-top:3px;display:block;}
.lnkbox{background:#fff;border:1.5px solid #c9a55a;border-radius:10px;padding:14px 18px;display:flex;gap:12px;align-items:flex-start;margin-bottom:18px;}
.lnkbox code{flex:1;font-size:11px;color:#5a3a10;font-family:monospace;line-height:1.5;word-break:break-all;}
.cpbtn{padding:9px 14px;background:#1d2322;border:none;color:#c9a55a;border-radius:6px;cursor:pointer;font-family:‘Lato’,sans-serif;font-size:13px;font-weight:600;white-space:nowrap;flex-shrink:0;transition:all .2s;}
.cpbtn.done{background:#e8f5e9;color:#2e7d32;}
.ct-wrap{background:#fff;border:1.5px solid #e0d0b0;border-radius:10px;overflow:hidden;margin-bottom:20px;}
.ct-head{background:#1d2322;padding:11px 20px;}
.ct-head span{font-family:‘Cormorant Garamond’,serif;font-size:14px;color:#c9a55a;}
/* ── Styles du contrat (utilisés à l’écran ET à l’impression) ── */
.ct{font-family:‘Georgia’,serif;font-size:13.5px;line-height:1.85;color:#1d2322;padding:28px 36px;}
@media(max-width:520px){.ct{padding:14px 12px;font-size:12px;}}
.ct h2{text-align:center;font-family:‘Cormorant Garamond’,serif;font-size:20px;font-weight:700;letter-spacing:1px;border-bottom:2px solid #c9a55a;padding-bottom:10px;margin-bottom:18px;}
.ct .bl{background:#fdf9f0;border:1px solid #e8d9b8;border-radius:5px;padding:10px 14px;margin-bottom:10px;}
.ct .ar{margin-bottom:11px;}
.ct .ar p:first-child{font-weight:700;margin-bottom:2px;}
.sigs{margin-top:22px;padding-top:14px;border-top:1.5px solid #e0d0b0;display:flex;gap:24px;flex-wrap:wrap;}
.sbox{flex:1;min-width:150px;}
.sbox .stitle{font-weight:700;font-size:12px;margin-bottom:4px;}
.sbox .sname{font-size:11px;color:#7a6a30;font-weight:600;margin-bottom:5px;}
.sbox .sname-gray{font-size:11px;color:#888;margin-bottom:5px;}
.vl{color:#7a6a30;font-weight:600;}
.scr{display:none;}.scr.on{display:block;}
#login-bg{min-height:100vh;background:#1d2322;display:none;align-items:center;justify-content:center;}
#login-bg.on{display:flex;}
.lbox{background:#252d2c;border:1px solid #2a3332;border-radius:14px;padding:48px 44px;width:340px;max-width:94vw;text-align:center;box-shadow:0 20px 60px rgba(0,0,0,.5);}

/* ═══════════════════════════════════
IMPRESSION — règles strictes
• Seul #pz s’imprime
• position:static + pas de fixed → pas de répétition
• page-break évite les chevauchements
═══════════════════════════════════ */
@media print {
/* Cacher absolument tout */
html, body { background: #fff !important; }
body > * { display: none !important; }

/* Seul #pz visible, flux normal (pas fixed, pas absolute) */
#pz {
display: block !important;
position: static !important;
width: 100% !important;
margin: 0 !important;
padding: 0 !important;
border: none !important;
background: #fff !important;
}

/* Contrat en flux normal pour pagination naturelle */
#pz .ct {
font-size: 11px !important;
line-height: 1.6 !important;
padding: 12px 20px !important;
color: #000 !important;
}
#pz .ct h2 { font-size: 15px !important; margin-bottom: 10px !important; }
#pz .ct .bl {
background: #fff !important;
border: 1px solid #ccc !important;
padding: 6px 10px !important;
margin-bottom: 7px !important;
}
#pz .ct .ar { margin-bottom: 7px !important; }

/* Empêcher la coupure dans les blocs critiques */
#pz .ct .bl,
#pz .ct .ar,
#pz .sigs { page-break-inside: avoid !important; break-inside: avoid !important; }

/* Signatures : ne pas couper entre titre et image */
#pz .sigs { margin-top: 10px !important; }
#pz .sbox { page-break-inside: avoid !important; break-inside: avoid !important; }

/* Images de signature : taille fixe, pas de débordement */
#pz .sig-img {
display: block !important;
width: 160px !important;
height: 55px !important;
object-fit: contain !important;
border: 1px solid #ccc !important;
background: #fff !important;
}
}
</style>

